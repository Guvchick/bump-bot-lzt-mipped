# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs allowed to control the bot (whitelist).
# Find yours via @userinfobot.
OWNER_IDS=123456789

# ── Storage ───────────────────────────────────────────────────────────────
DB_PATH=./bot.db

# ── Secrets encryption ────────────────────────────────────────────────────
# 32 bytes, base64-encoded. Generate one with:
#   openssl rand -base64 32
# All tokens/passwords/cookies in the DB are AES-256-GCM encrypted with this key.
# Losing/changing it makes stored secrets unreadable.
ENCRYPTION_KEY=

# ── Scheduling defaults (also editable in the panel → ⚙️ Настройки) ────────
DEFAULT_INTERVAL_SEC=86400   # default bump interval for Mipped (24h limit)
LOLZ_INTERVAL_SEC=14400      # default bump interval for Lolzteam (forum cooldown)
JITTER_SEC=1800              # random 0..N seconds added to each next-bump time
STATS_POLL_SEC=3600          # how often to snapshot thread stats
REQUEST_DELAY_MS=3000        # global minimum delay between forum requests

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warn | error
